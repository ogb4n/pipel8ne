# Base de données MongoDB
DATABASE_URL=mongodb://localhost:27017/pipel8ne

# JWT — Remplacez par une clé aléatoire longue en production
# Génération : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=changeme-use-a-long-random-string-in-production

# Chiffrement AES-256-GCM des secrets de nodes (obligatoire)
# Génération : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRETS_ENCRYPTION_KEY=changeme-64-hex-chars-32-bytes-replace-in-production-000000000000

# URL du frontend (utilisé pour les redirections OAuth)
FRONTEND_URL=http://localhost:5173

# GitHub OAuth (optionnel — pour activer la connexion GitHub)
# Créez une OAuth App sur https://github.com/settings/developers
# Callback URL : http://localhost:5173/oauth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitLab OAuth (optionnel — pour activer la connexion GitLab)
# Créez une application sur https://gitlab.com/-/user_settings/applications
# Callback URL : http://localhost:5173/oauth/callback
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_BASE_URL=https://gitlab.com

NODE_ENV=development
