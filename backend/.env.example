# Base de données MongoDB
DATABASE_URL=mongodb://localhost:27017/pipel8ne

# JWT — Remplacez par une clé aléatoire longue en production
# Génération : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=changeme-use-a-long-random-string-in-production

# Chiffrement AES-256-GCM des secrets de nodes (obligatoire)
# Génération : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRETS_ENCRYPTION_KEY=changeme-64-hex-chars-32-bytes-replace-in-production-000000000000

NODE_ENV=development
