{
  "name": "backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "typeorm migration:run -d dist/infrastructure/database/client.js",
    "db:migrate:dev": "typeorm-ts-node-commonjs migration:run -d src/infrastructure/database/client.ts",
    "db:migrate:generate": "typeorm-ts-node-commonjs migration:generate -d src/infrastructure/database/client.ts src/infrastructure/database/migrations/Migration",
    "db:migrate:revert": "typeorm-ts-node-commonjs migration:revert -d src/infrastructure/database/client.ts"
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "dotenv": "^16.0.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "pg": "^8.0.0",
    "pino-pretty": "^13.0.0",
    "reflect-metadata": "^0.2.0",
    "typeorm": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
